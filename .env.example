# ─────────────────────────────────────────────────────────────
# Bot de Recordatorios Personales - Variables de Entorno
# ─────────────────────────────────────────────────────────────
# Copia este archivo como ".env" y rellena tus valores.
# NUNCA subas el archivo .env a GitHub.

# Token de tu bot de Telegram (obtenido de @BotFather)
TELEGRAM_TOKEN=tu_token_aqui

# Tu ID de usuario de Telegram (seguridad: solo tú puedes usar el bot)
# Cómo obtenerlo: escríbele a @userinfobot en Telegram
AUTHORIZED_USER_ID=123456789

# Zona horaria (lista completa: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TIMEZONE=America/Bogota

# Minutos de anticipación para el recordatorio previo (por defecto 60 = 1 hora antes)
REMINDER_MINUTES_BEFORE=60

# ─── Google API ───────────────────────────────────────────────
# Ruta al archivo credentials.json descargado de Google Cloud Console
GOOGLE_CREDENTIALS_FILE=credentials.json
# Ruta donde se guardará el token de acceso
GOOGLE_TOKEN_FILE=token.json

# ─── Para Railway/Cloud (en lugar de archivos, usa estas variables) ───────────
# Codifica credentials.json en base64: python -c "import base64,open;print(base64.b64encode(open('credentials.json','rb').read()).decode())"
# GOOGLE_CREDENTIALS_BASE64=

# Codifica token.json en base64 (después de ejecutar setup_google.py):
# GOOGLE_TOKEN_BASE64=
